  .comp-card-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
  }
  .comp-card-country {
    font-size: 11px;
    color: var(--text-secondary);
    margin-top: 2px;
  }

  /* Leader row inside comp card */
  .comp-leader {
    border-top: 1px solid var(--border-subtle);
    padding: 8px 12px;
    background: var(--bg-surface-alt);
    display: flex;
    align-items: center;
    gap: 8px;
