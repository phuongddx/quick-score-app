  .form-d { background: var(--accent-warning); color: #000; }
  .form-l { background: var(--accent-danger); color: #fff; }

  /* Standing position badge */
  .position-badge {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    color: var(--text-secondary);
  }
  .pos-indicator {
    width: 8px; height: 8px; border-radius: 2px;
    flex-shrink: 0;
  }

  /* ── Competition Card ────────────────────────────────────── */
  .comp-card {
    background: var(--bg-surface);
    margin: 0 12px 8px;
    border-radius: 10px;
    border: 1px solid var(--border-subtle);
    overflow: hidden;
    cursor: pointer;
    transition: border-color 200ms;
  }
  .comp-card:hover { border-color: var(--border); }

  .comp-card-header {
    display: flex;
    align-items: center;
    padding: 12px;
    gap: 12px;
