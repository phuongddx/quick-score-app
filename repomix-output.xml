    font-size: 12px;
    font-weight: 700;
    color: var(--text-primary);
  }

  /* ── Empty State ─────────────────────────────────────────── */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 48px 32px;
    gap: 16px;
    text-align: center;
