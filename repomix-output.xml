  .empty-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-primary);
  }
  .empty-desc {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.5;
    max-width: 260px;
  }
  .empty-cta {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--accent-blue);
