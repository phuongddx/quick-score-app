          <Animated.Text
            style={{ color: '#E6EDF3', fontSize: 48, fontWeight: '700', fontVariant: ['tabular-nums'], opacity: flash }}
          >
            {score.home} - {score.away}
          </Animated.Text>
          <StatusPill status={status} minute={minute} />
