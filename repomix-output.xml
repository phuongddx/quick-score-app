<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=375, initial-scale=1.0">
<title>Quick Score – Match Detail</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg-primary:     #0D1117;
    --bg-surface:     #161B22;
    --bg-surface-alt: #1C2128;
    --bg-elevated:    #21262D;
    --border:         #30363D;
    --border-subtle:  #21262D;
    --text-primary:   #E6EDF3;
    --text-secondary: #8B949E;
    --text-muted:     #484F58;
    --accent-live:    #00C853;
    --accent-live-dim:rgba(0,200,83,0.10);
    --accent-danger:  #FF3D3D;
    --accent-warning: #FFB300;
    --accent-blue:    #2196F3;
    --accent-blue-dim:rgba(33,150,243,0.12);
    --font-main: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-mono: 'Roboto Mono', 'SF Mono', monospace;
  }

  body {
    font-family: var(--font-main);
    background: var(--bg-primary);
    color: var(--text-primary);
    width: 375px;
    margin: 0 auto;
    font-size: 14px;
    overflow-x: hidden;
  }

  /* ── Status Bar ─────────────────────────────────────────── */
  .status-bar {
    height: 44px;
    background: var(--bg-surface);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px;
  }
  .status-bar .time { font-size: 15px; font-weight: 600; }

  /* ── Nav Bar ─────────────────────────────────────────────── */
  .nav-bar {
    height: 44px;
    background: var(--bg-surface);
    border-bottom: 1px solid var(--border-subtle);
    display: flex;
    align-items: center;
    padding: 0 8px;
    gap: 8px;
  }
  .back-btn {
    display: flex;
    align-items: center;
    gap: 4px;
    color: var(--accent-blue);
    font-size: 14px;
    cursor: pointer;
    padding: 8px;
    border-radius: 6px;
    min-height: 44px;
  }
  .nav-title {
    flex: 1;
    text-align: center;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .nav-action {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    cursor: pointer;
  }

  /* ── Match Hero ──────────────────────────────────────────── */
  .match-hero {
    background: var(--bg-surface);
    padding: 16px 16px 0;
    border-bottom: 1px solid var(--border-subtle);
  }

  /* Competition row */
  .match-competition {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-bottom: 16px;
  }
  .comp-flag {
    width: 16px;
    height: 12px;
    border-radius: 2px;
    background: linear-gradient(#012169 33%, #fff 33%, #fff 50%, #C8102E 50%);
  }
  .comp-name {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .comp-round {
    font-size: 11px;
    color: var(--text-muted);
  }

  /* Score block */
  .score-block {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 8px 16px;
    gap: 8px;
  }
  .team-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .team-crest-lg {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 700;
    color: #fff;
  }
  .team-name-lg {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    text-align: center;
  }

  .score-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    min-width: 100px;
  }
  .score-display {
    font-family: var(--font-mono);
    font-size: 48px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -2px;
    line-height: 1;
  }
  .score-sep {
    color: var(--text-muted);
    font-size: 36px;
    margin: 0 2px;
    font-weight: 300;
  }

  /* Live status pill */
  .live-status {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(0,200,83,0.15);
    border: 1px solid rgba(0,200,83,0.3);
    border-radius: 12px;
    padding: 3px 10px;
  }
  .live-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent-live);
    animation: live-pulse 1.5s ease-in-out infinite;
  }
  @keyframes live-pulse {
    0%   { opacity: 1;   transform: scale(1); }
    50%  { opacity: 0.4; transform: scale(1.6); }
    100% { opacity: 1;   transform: scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .live-dot { animation: none; }
  }
  .live-time {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    color: var(--accent-live);
  }

  /* Goal scorers mini */
  .goal-scorers {
    display: flex;
    justify-content: space-between;
    padding: 0 0 12px;
  }
  .scorer-list {
    flex: 1;
    font-size: 11px;
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .scorer-list.home { text-align: left; padding-right: 60px; }
  .scorer-list.away { text-align: right; padding-left: 60px; }
  .scorer-list span { color: var(--text-muted); font-size: 10px; }

  /* ── Tab Strip ───────────────────────────────────────────── */
  .tab-strip {
    background: var(--bg-surface);
    display: flex;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 88px;
    z-index: 30;
  }
  .tab-strip-item {
    flex: 1;
    padding: 12px 4px;
    text-align: center;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-muted);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 200ms ease;
    letter-spacing: 0.3px;
  }
  .tab-strip-item.active {
    color: var(--accent-blue);
    border-bottom-color: var(--accent-blue);
  }

  /* ── Content Sections ────────────────────────────────────── */
  .content-area {
    padding-bottom: 72px;
  }

  /* Section label */
  .section-label {
    padding: 12px 16px 6px;
    font-size: 11px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.6px;
  }

  /* ── Event Timeline ──────────────────────────────────────── */
  .timeline {
    padding: 0 16px;
  }

  .timeline-event {
    display: flex;
    align-items: flex-start;
    min-height: 40px;
    position: relative;
  }

  /* Centre divider line */
  .timeline::before {
    content: '';
    position: absolute;
    left: calc(50% - 0.5px);
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--border-subtle);
    pointer-events: none;
  }
  .timeline { position: relative; }

  .event-home {
    flex: 1;
    text-align: right;
    padding-right: 20px;
    padding: 8px 20px 8px 0;
  }
  .event-away {
    flex: 1;
    text-align: left;
    padding: 8px 0 8px 20px;
  }
  .event-minute {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    color: var(--text-muted);
    background: var(--bg-primary);
    padding: 2px 4px;
    border-radius: 3px;
    z-index: 2;
  }

  .event-player {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-primary);
  }
  .event-type-label {
    font-size: 10px;
    color: var(--text-secondary);
    margin-top: 1px;
  }

  .event-icon {
    display: inline-block;
    width: 16px;
    height: 16px;
    border-radius: 3px;
    font-size: 9px;
    font-weight: 700;
    text-align: center;
    line-height: 16px;
    margin-left: 4px;
    vertical-align: middle;
  }
  .event-icon.goal  { background: var(--accent-live); color: #000; }
  .event-icon.yellow { background: var(--accent-warning); color: #000; }
  .event-icon.red   { background: var(--accent-danger); color: #fff; }
  .event-icon.sub   { background: var(--bg-elevated); color: var(--text-secondary); }
  .event-icon-home { margin-left: 4px; }
  .event-icon-away { margin-right: 4px; }

  /* ── Stats Bars ──────────────────────────────────────────── */
  .stats-section { padding: 0 16px; }

  .stat-row {
    display: flex;
    align-items: center;
    margin-bottom: 16px;
    gap: 8px;
  }
  .stat-val {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    min-width: 32px;
    text-align: center;
  }
  .stat-bar-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 3px;
  }
  .stat-bar-home {
    height: 4px;
    border-radius: 2px;
    background: var(--accent-blue);
    flex: var(--home-pct, 50);
    transition: flex 300ms ease;
  }
  .stat-bar-away {
    height: 4px;
    border-radius: 2px;
    background: var(--text-muted);
    flex: var(--away-pct, 50);
  }
  .stat-label {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    font-size: 10px;
    color: var(--text-muted);
  }
  .stat-row-inner {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .stat-name {
    font-size: 11px;
    color: var(--text-secondary);
    text-align: center;
  }

  /* ── Lineups ─────────────────────────────────────────────── */
  .lineup-section {
    padding: 0 16px;
  }

  /* Formation pitch */
  .pitch {
    background: linear-gradient(180deg, #0a2e0a 0%, #0d3d0d 25%, #0a2e0a 50%, #0d3d0d 75%, #0a2e0a 100%);
    border-radius: 8px;
    border: 1px solid #1a4d1a;
    padding: 16px 8px;
    margin-bottom: 12px;
    position: relative;
  }
  /* Centre line */
  .pitch::after {
    content: '';
    position: absolute;
    left: 12px;
    right: 12px;
    top: 50%;
    height: 1px;
    background: rgba(255,255,255,0.08);
  }
  /* Centre circle placeholder */
  .pitch-centre-circle {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.08);
  }

  .formation-row {
    display: flex;
    justify-content: space-around;
    margin-bottom: 14px;
  }
  .formation-row:last-child { margin-bottom: 0; }

  .player-dot {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    cursor: pointer;
  }
  .player-circle {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 700;
    color: #fff;
    border: 2px solid rgba(255,255,255,0.2);
  }
  .player-circle.home { background: #EF0107; } /* Arsenal red */
  .player-circle.away { background: #97C1E7; color: #000; } /* Man City blue */
  .player-circle.gk   { background: #FF9800; color: #000; }
  .player-num {
    font-size: 8px;
    font-weight: 600;
    position: absolute;
    color: rgba(255,255,255,0.7);
  }
  .player-name-dot {
    font-size: 9px;
    color: rgba(255,255,255,0.7);
    text-align: center;
    max-width: 44px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Bench list */
  .bench-list {
    background: var(--bg-surface);
    border-radius: 8px;
    overflow: hidden;
  }
  .bench-header {
    padding: 8px 12px;
    font-size: 11px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 1px solid var(--border-subtle);
  }
  .bench-row {
    display: flex;
    align-items: center;
    padding: 8px 12px;
    gap: 10px;
    border-bottom: 1px solid var(--border-subtle);
  }
  .bench-row:last-child { border-bottom: none; }
  .bench-num {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--text-muted);
    min-width: 20px;
  }
  .bench-name {
    flex: 1;
    font-size: 13px;
    color: var(--text-primary);
  }
  .bench-pos {
    font-size: 10px;
    font-weight: 600;
    color: var(--text-muted);
    width: 24px;
    text-align: center;
    background: var(--bg-elevated);
    border-radius: 3px;
    padding: 2px 4px;
  }
  .sub-in { color: var(--accent-live); font-size: 10px; margin-left: 4px; }

  /* ── Bottom Tab Bar ──────────────────────────────────────── */
  .bottom-tabs {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 375px;
    height: 56px;
    background: var(--bg-surface);
    border-top: 1px solid var(--border);
    display: flex;
    align-items: stretch;
    z-index: 100;
  }
  .tab-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    cursor: pointer;
    color: var(--text-muted);
    min-height: 44px;
  }
  .tab-item.active { color: var(--accent-blue); }
  .tab-item svg { width: 22px; height: 22px; }
  .tab-label { font-size: 10px; font-weight: 500; }

  /* Crest colors */
  .crest-arsenal   { background: #EF0107; }
  .crest-mancity   { background: #97C1E7; color: #000 !important; }

  /* Annotation block */
  .annotation-block {
