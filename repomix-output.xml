    font-size: 14px;
    font-weight: 600;
    padding: 10px 20px;
    border-radius: 22px;
    cursor: pointer;
    transition: opacity 200ms;
  }
  .empty-cta:hover { opacity: 0.88; }

  /* ── Add Favorites CTA ───────────────────────────────────── */
  .add-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0 12px 8px;
    padding: 12px;
    border: 1px dashed var(--border);
    border-radius: 10px;
    cursor: pointer;
    color: var(--text-muted);
    font-size: 13px;
    transition: all 200ms;
  }
  .add-row:hover {
    border-color: var(--accent-blue);
    color: var(--accent-blue);
    background: var(--accent-blue-dim);
  }
  .add-row svg { width: 18px; height: 18px; flex-shrink: 0; }

