<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=375, initial-scale=1.0">
<title>Quick Score – Live Scores</title>
<style>
  /* ── Reset & Base ─────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg-primary:     #0D1117;
    --bg-surface:     #161B22;
    --bg-surface-alt: #1C2128;
    --bg-elevated:    #21262D;
    --border:         #30363D;
    --border-subtle:  #21262D;
    --text-primary:   #E6EDF3;
    --text-secondary: #8B949E;
    --text-muted:     #484F58;
    --accent-live:    #00C853;
    --accent-live-dim:rgba(0,200,83,0.10);
    --accent-danger:  #FF3D3D;
    --accent-warning: #FFB300;
    --accent-blue:    #2196F3;
    --accent-blue-dim:rgba(33,150,243,0.12);
    --font-main: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-mono: 'Roboto Mono', 'SF Mono', monospace;
  }

  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Roboto+Mono:wght@500;700&display=swap');

  body {
    font-family: var(--font-main);
    background: var(--bg-primary);
    color: var(--text-primary);
    width: 375px;
    min-height: 812px;
    margin: 0 auto;
    position: relative;
    overflow-x: hidden;
    font-size: 14px;
  }

  /* ── Status Bar ───────────────────────────────────────────── */
  .status-bar {
    height: 44px;
    background: var(--bg-primary);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px;
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .status-bar .time {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
  }
  .status-bar .indicators {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .status-bar .indicators svg {
    fill: var(--text-primary);
  }

  /* ── Top App Bar ──────────────────────────────────────────── */
  .app-bar {
    background: var(--bg-primary);
    padding: 8px 16px 0;
    position: sticky;
    top: 44px;
    z-index: 40;
    border-bottom: 1px solid var(--border-subtle);
  }
  .app-bar-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 44px;
  }
  .app-title {
    font-size: 20px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.3px;
  }
  .app-title span { color: var(--accent-live); }
  .app-bar-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .icon-btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    cursor: pointer;
    color: var(--text-secondary);
    transition: background 200ms ease;
  }
  .icon-btn:hover { background: var(--bg-surface-alt); }

  /* ── Date Filter Strip ────────────────────────────────────── */
  .date-strip {
    background: var(--bg-primary);
    height: 56px;
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 0 12px;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  .date-strip::-webkit-scrollbar { display: none; }
  .date-pill {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 6px 12px;
    border-radius: 20px;
    cursor: pointer;
    min-width: 52px;
    transition: background 200ms ease;
  }
  .date-pill .day-name {
    font-size: 10px;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.4px;
  }
  .date-pill .day-num {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-secondary);
    margin-top: 1px;
  }
  .date-pill.active {
    background: var(--accent-blue);
  }
  .date-pill.active .day-name,
  .date-pill.active .day-num { color: #fff; }
  .date-pill:not(.active):hover { background: var(--bg-surface-alt); }
  .date-pill.today .day-num { color: var(--text-primary); }

  /* Live Matches Summary Bar */
  .live-summary {
    background: var(--bg-surface);
    border-bottom: 1px solid var(--border-subtle);
    padding: 8px 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent-live);
    flex-shrink: 0;
    animation: live-pulse 1.5s ease-in-out infinite;
  }
  @keyframes live-pulse {
    0%   { opacity: 1;   transform: scale(1); }
    50%  { opacity: 0.4; transform: scale(1.6); }
    100% { opacity: 1;   transform: scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .live-dot { animation: none; }
  }
  .live-summary-text {
    font-size: 12px;
    font-weight: 500;
    color: var(--accent-live);
  }
  .live-summary-text span {
    color: var(--text-secondary);
    font-weight: 400;
    margin-left: 4px;
  }

  /* ── Match Feed ───────────────────────────────────────────── */
  .feed {
    flex: 1;
    padding-bottom: 72px; /* bottom tab height */
  }

  /* ── Competition Section ──────────────────────────────────── */
  .competition-header {
    background: var(--bg-surface);
    height: 40px;
    display: flex;
    align-items: center;
    padding: 0 12px;
    border-bottom: 1px solid var(--border-subtle);
    cursor: pointer;
    gap: 8px;
    position: sticky;
    top: 188px; /* status + appbar + datestrip + livebar */
    z-index: 10;
  }
  .competition-flag {
    width: 18px;
    height: 13px;
    border-radius: 2px;
    object-fit: cover;
    flex-shrink: 0;
  }
  /* Flag placeholders */
  .flag-en { background: linear-gradient(#012169 33%, #fff 33%, #fff 50%, #C8102E 50%); }
  .flag-es { background: linear-gradient(#AA151B 25%, #F1BF00 25%, #F1BF00 75%, #AA151B 75%); }
  .flag-de { background: linear-gradient(#000 33%, #D00 33%, #D00 67%, #FFCE00 67%); }
  .flag-it { background: linear-gradient(90deg, #009246 33%, #fff 33%, #fff 67%, #CE2B37 67%); }
  .flag-fr { background: linear-gradient(90deg, #002395 33%, #fff 33%, #fff 67%, #ED2939 67%); }
  .flag-eu { background: #003399; }

  .competition-name {
    font-size: 12px;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    flex: 1;
  }
  .competition-live-count {
    font-size: 11px;
    font-weight: 600;
    color: var(--accent-live);
    margin-right: 4px;
  }
  .competition-chevron {
    color: var(--text-muted);
    transition: transform 250ms ease;
  }
  .competition-header.collapsed .competition-chevron {
    transform: rotate(-90deg);
  }

  /* ── Match Card ───────────────────────────────────────────── */
  .match-card {
    background: var(--bg-primary);
    border-bottom: 1px solid var(--border-subtle);
    padding: 0 12px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 64px;
    cursor: pointer;
    transition: background 150ms ease;
  }
  .match-card:hover { background: var(--bg-surface-alt); }
  .match-card.live { background: var(--accent-live-dim); }
  .match-card.live:hover { background: rgba(0,200,83,0.16); }

  .match-row {
    display: flex;
    align-items: center;
    height: 28px;
  }
  .team-crest {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    color: #fff;
    margin-right: 8px;
  }
  .team-name {
    flex: 1;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .team-name.scorer { font-weight: 600; }
  .team-score {
    font-family: var(--font-mono);
    font-size: 18px;
    font-weight: 700;
    color: var(--text-primary);
    min-width: 28px;
    text-align: center;
    margin-left: 8px;
  }
  .team-score.updated {
    animation: goal-flash 1.2s ease-out forwards;
  }
  @keyframes goal-flash {
    0%   { color: var(--text-primary); }
    20%  { color: var(--accent-goal); }
    100% { color: var(--text-primary); }
  }

  /* Match meta row (time, events) */
  .match-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 2px 0 4px 32px; /* indent under crest */
  }
  .match-time {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--accent-live);
    min-width: 28px;
  }
  .match-time.scheduled {
    color: var(--text-secondary);
  }
  .match-time.finished {
    color: var(--text-muted);
  }
  .live-badge {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .live-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-live);
    animation: live-pulse 1.5s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .live-badge-dot { animation: none; }
  }
  .live-badge-text {
    font-size: 10px;
    font-weight: 600;
    color: var(--accent-live);
    letter-spacing: 0.5px;
  }

  /* Card pill indicators */
  .event-pills {
    display: flex;
    align-items: center;
    gap: 3px;
    margin-left: auto;
  }
  .card-pill {
    font-size: 10px;
    font-weight: 700;
    padding: 1px 4px;
    border-radius: 3px;
    color: #fff;
  }
  .card-pill.yellow { background: var(--accent-warning); }
  .card-pill.red    { background: var(--accent-danger); }
  .card-pill.goal   {
    background: var(--accent-live);
    color: #000;
    font-size: 9px;
  }

  /* Half time / FT tags */
  .match-status-tag {
    font-size: 10px;
    font-weight: 600;
    padding: 2px 5px;
    border-radius: 3px;
    background: var(--bg-surface);
    color: var(--text-muted);
    letter-spacing: 0.3px;
  }
  .match-status-tag.ht { color: var(--accent-warning); }

  /* ── Annotation Labels ────────────────────────────────────── */
  .annotation {
    position: relative;
  }
  .ann-label {
    position: absolute;
    right: -130px;
    background: #1a1f2e;
    border: 1px solid #3d4663;
    color: #7b8cde;
    font-size: 10px;
    padding: 2px 6px;
    border-radius: 4px;
    white-space: nowrap;
    pointer-events: none;
    font-family: var(--font-mono);
  }
  .ann-line {
    position: absolute;
    right: -2px;
    top: 50%;
    width: 14px;
    height: 1px;
    background: #3d4663;
  }

  /* ── Bottom Tab Bar ───────────────────────────────────────── */
  .bottom-tabs {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 375px;
    height: 56px;
    background: var(--bg-surface);
    border-top: 1px solid var(--border);
    display: flex;
    align-items: stretch;
    z-index: 100;
    padding-bottom: 0; /* adjust for safe area in real app */
  }
  .tab-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    cursor: pointer;
    position: relative;
    color: var(--text-muted);
    transition: color 200ms ease;
    min-height: 44px;
  }
  .tab-item.active { color: var(--accent-blue); }
  .tab-item svg { width: 22px; height: 22px; }
  .tab-label {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2px;
  }
  .tab-badge {
    position: absolute;
    top: 6px;
    right: calc(50% - 14px);
    background: var(--accent-live);
    color: #000;
    font-size: 9px;
    font-weight: 700;
    min-width: 14px;
    height: 14px;
    border-radius: 7px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 3px;
  }

  /* ── Wireframe annotation sidebar ────────────────────────── */
  .wireframe-wrapper {
    position: relative;
    width: 375px;
    margin: 0 auto;
  }
  .sidebar-note {
    position: absolute;
    left: 383px;
    background: #0a0e1a;
    border: 1px solid #2a3050;
    border-radius: 6px;
    padding: 6px 10px;
    font-size: 11px;
    color: #6b7db3;
    font-family: var(--font-mono);
    white-space: nowrap;
    max-width: 200px;
    white-space: normal;
    line-height: 1.4;
  }
  .sidebar-note::before {
    content: '';
    position: absolute;
    left: -8px;
    top: 50%;
    transform: translateY(-50%);
    border: 4px solid transparent;
    border-right-color: #2a3050;
  }

  /* Team crest colors (demo) */
  .crest-mancity  { background: #97C1E7; }
  .crest-arsenal  { background: #EF0107; }
  .crest-liverpool{ background: #C8102E; }
  .crest-chelsea  { background: #034694; }
  .crest-spurs    { background: #132257; }
  .crest-manu     { background: #DA020E; }
  .crest-newcastle{ background: #241F20; border: 1px solid #444; }
  .crest-aston    { background: #95BFE5; }
  .crest-brentford{ background: #E30613; }
  .crest-wolves   { background: #FDB913; }
  .crest-realmadrid{ background: #FABE00; }
  .crest-barca    { background: #A50044; }
  .crest-atletico { background: #CB3524; }
  .crest-dortmund { background: #FDE100; }
  .crest-bayern   { background: #DC052D; }

  /* Scrollable content note */
  .scroll-indicator {
    text-align: center;
    padding: 16px;
    color: var(--text-muted);
    font-size: 12px;
    border-top: 1px dashed var(--border-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }
</style>
</head>
<body>

