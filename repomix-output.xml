<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=375, initial-scale=1.0">
<title>Quick Score – Standings</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg-primary:     #0D1117;
    --bg-surface:     #161B22;
    --bg-surface-alt: #1C2128;
    --bg-elevated:    #21262D;
    --border:         #30363D;
    --border-subtle:  #21262D;
    --text-primary:   #E6EDF3;
    --text-secondary: #8B949E;
    --text-muted:     #484F58;
    --accent-live:    #00C853;
    --accent-danger:  #FF3D3D;
    --accent-warning: #FFB300;
    --accent-blue:    #2196F3;
    --data-cl:        #00C853;
    --data-el:        #FF9800;
    --data-ecl:       #9C27B0;
    --data-relegation:#FF3D3D;
    --font-main: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-mono: 'Roboto Mono', 'SF Mono', monospace;
  }

  body {
    font-family: var(--font-main);
    background: var(--bg-primary);
    color: var(--text-primary);
    width: 375px;
    margin: 0 auto;
    font-size: 14px;
    overflow-x: hidden;
  }

  /* ── Status Bar ─────────────────────────────────────────── */
  .status-bar {
    height: 44px;
    background: var(--bg-primary);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px;
  }
  .status-bar .time { font-size: 15px; font-weight: 600; }

  /* ── App Bar ─────────────────────────────────────────────── */
  .app-bar {
    height: 44px;
    background: var(--bg-primary);
    display: flex;
    align-items: center;
    padding: 0 16px;
    border-bottom: 1px solid var(--border-subtle);
  }
  .app-bar-title {
    font-size: 20px;
    font-weight: 700;
    flex: 1;
  }
  .icon-btn {
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    color: var(--text-secondary); cursor: pointer; border-radius: 50%;
  }

  /* ── League Selector Strip ───────────────────────────────── */
  .league-strip {
    background: var(--bg-surface);
    height: 52px;
    display: flex;
    align-items: center;
    gap: 0;
    padding: 0 8px;
    overflow-x: auto;
    scrollbar-width: none;
    border-bottom: 1px solid var(--border-subtle);
    position: sticky;
    top: 88px;
    z-index: 40;
  }
  .league-strip::-webkit-scrollbar { display: none; }
  .league-tab {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 20px;
    cursor: pointer;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-secondary);
    white-space: nowrap;
    transition: all 200ms ease;
  }
  .league-tab.active {
    background: var(--accent-blue);
    color: #fff;
  }
  .league-tab:not(.active):hover {
    background: var(--bg-surface-alt);
  }
  .league-flag {
    width: 16px; height: 12px; border-radius: 2px; flex-shrink: 0;
  }
  .flag-en { background: linear-gradient(#012169 33%,#fff 33%,#fff 50%,#C8102E 50%); }
  .flag-es { background: linear-gradient(#AA151B 25%,#F1BF00 25%,#F1BF00 75%,#AA151B 75%); }
  .flag-de { background: linear-gradient(#000 33%,#D00 33%,#D00 67%,#FFCE00 67%); }
  .flag-it { background: linear-gradient(90deg,#009246 33%,#fff 33%,#fff 67%,#CE2B37 67%); }
  .flag-fr { background: linear-gradient(90deg,#002395 33%,#fff 33%,#fff 67%,#ED2939 67%); }

  /* ── Season/Round Selector ───────────────────────────────── */
  .round-bar {
    background: var(--bg-surface);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 16px;
    border-bottom: 1px solid var(--border-subtle);
  }
  .round-selector {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
    cursor: pointer;
  }
  .season-label {
    font-size: 12px;
    color: var(--text-muted);
  }

  /* ── Table Header ────────────────────────────────────────── */
  .table-header {
    background: var(--bg-surface);
    display: flex;
    align-items: center;
    padding: 6px 12px;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 140px;
    z-index: 30;
  }
