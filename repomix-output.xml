        <div class="player-dot">
          <div class="player-circle away" style="font-size:8px;">SAV<br>25</div>
          <div class="player-name-dot">Savinho</div>
        </div>
      </div>
      <!-- ST Man City -->
      <div class="formation-row" style="margin-top:14px;">
        <div class="player-dot">
          <div class="player-circle away" style="font-size:8px;">HAA<br>9</div>
          <div class="player-name-dot">Haaland</div>
        </div>
      </div>

    </div><!-- /pitch -->

    <!-- Bench -->
    <div class="bench-list">
      <div class="bench-header">Substitutes</div>
      <div class="bench-row">
        <span class="bench-num">13</span>
