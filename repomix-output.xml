<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=375, initial-scale=1.0">
<title>Quick Score – Fixtures</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg-primary:     #0D1117;
    --bg-surface:     #161B22;
    --bg-surface-alt: #1C2128;
    --bg-elevated:    #21262D;
    --border:         #30363D;
    --border-subtle:  #21262D;
    --text-primary:   #E6EDF3;
    --text-secondary: #8B949E;
    --text-muted:     #484F58;
    --accent-live:    #00C853;
    --accent-danger:  #FF3D3D;
    --accent-warning: #FFB300;
    --accent-blue:    #2196F3;
    --font-main: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-mono: 'Roboto Mono', 'SF Mono', monospace;
  }

  body {
    font-family: var(--font-main);
    background: var(--bg-primary);
    color: var(--text-primary);
    width: 375px;
    margin: 0 auto;
    font-size: 14px;
    overflow-x: hidden;
  }

  /* ── Status Bar ─────────────────────────────────────────── */
  .status-bar {
    height: 44px;
    background: var(--bg-primary);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px;
  }
  .status-bar .time { font-size: 15px; font-weight: 600; }

  /* ── App Bar ─────────────────────────────────────────────── */
  .app-bar {
    height: 44px;
    background: var(--bg-primary);
    display: flex;
    align-items: center;
    padding: 0 16px;
    border-bottom: 1px solid var(--border-subtle);
    gap: 8px;
  }
  .app-bar-title { font-size: 20px; font-weight: 700; flex: 1; }
  .icon-btn {
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    color: var(--text-secondary); cursor: pointer; border-radius: 50%;
    transition: background 200ms;
  }
  .icon-btn:hover { background: var(--bg-surface-alt); }

  /* ── Date Strip ──────────────────────────────────────────── */
  .date-strip {
    background: var(--bg-primary);
    height: 60px;
    display: flex;
    align-items: center;
    padding: 0 12px;
    gap: 4px;
    overflow-x: auto;
    scrollbar-width: none;
    border-bottom: 1px solid var(--border-subtle);
    position: sticky;
    top: 88px;
    z-index: 40;
  }
  .date-strip::-webkit-scrollbar { display: none; }
  .date-pill {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 6px 10px;
    border-radius: 22px;
    cursor: pointer;
    min-width: 50px;
    transition: background 200ms ease;
    gap: 1px;
  }
  .date-pill .day-name {
    font-size: 10px;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.4px;
  }
  .date-pill .day-num {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-secondary);
  }
  .date-pill.today .day-num { color: var(--text-primary); }
  .date-pill.active {
    background: var(--accent-blue);
  }
  .date-pill.active .day-name,
  .date-pill.active .day-num { color: #fff; }
  .date-pill:not(.active):hover { background: var(--bg-surface-alt); }
  /* Match count dot */
  .date-pill .match-count {
    width: 4px; height: 4px;
    border-radius: 50%;
    background: var(--accent-blue);
    margin-top: 2px;
  }
  .date-pill.active .match-count { background: rgba(255,255,255,0.7); }

  /* ── Filter Bar ──────────────────────────────────────────── */
  .filter-bar {
    background: var(--bg-surface);
    display: flex;
    align-items: center;
    padding: 8px 12px;
    gap: 6px;
    border-bottom: 1px solid var(--border-subtle);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .filter-bar::-webkit-scrollbar { display: none; }
  .filter-chip {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 5px 10px;
    border-radius: 14px;
    border: 1px solid var(--border);
    font-size: 12px;
    font-weight: 500;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 200ms ease;
    white-space: nowrap;
  }
  .filter-chip.active {
    background: var(--accent-blue);
    border-color: var(--accent-blue);
    color: #fff;
  }
  .filter-chip:not(.active):hover {
    border-color: var(--text-secondary);
    color: var(--text-primary);
  }
  .filter-chip svg { width: 12px; height: 12px; }

  /* ── Feed ────────────────────────────────────────────────── */
  .feed { padding-bottom: 72px; }

  /* ── Date Group Header ───────────────────────────────────── */
  .date-group-header {
    background: var(--bg-surface-alt);
    padding: 8px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--border-subtle);
  }
  .date-group-label {
    font-size: 12px;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .date-group-count {
    font-size: 11px;
    color: var(--text-muted);
  }

  /* ── Competition Header (fixtures) ──────────────────────── */
  .comp-header {
    background: var(--bg-surface);
    height: 36px;
    display: flex;
    align-items: center;
    padding: 0 12px;
    gap: 8px;
    border-bottom: 1px solid var(--border-subtle);
    cursor: pointer;
  }
  .comp-flag {
    width: 16px; height: 12px; border-radius: 2px; flex-shrink: 0;
  }
  .flag-en { background: linear-gradient(#012169 33%,#fff 33%,#fff 50%,#C8102E 50%); }
  .flag-es { background: linear-gradient(#AA151B 25%,#F1BF00 25%,#F1BF00 75%,#AA151B 75%); }
  .flag-de { background: linear-gradient(#000 33%,#D00 33%,#D00 67%,#FFCE00 67%); }
  .flag-it { background: linear-gradient(90deg,#009246 33%,#fff 33%,#fff 67%,#CE2B37 67%); }
  .flag-eu { background: #003399; }
  .comp-name-sm {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    flex: 1;
  }
  .comp-round-sm {
    font-size: 10px;
    color: var(--text-muted);
  }

  /* ── Fixture Card ────────────────────────────────────────── */
  .fixture-card {
    background: var(--bg-primary);
    border-bottom: 1px solid var(--border-subtle);
    display: flex;
    align-items: center;
    padding: 0 12px;
    min-height: 60px;
    cursor: pointer;
    transition: background 150ms ease;
    gap: 8px;
  }
  .fixture-card:hover { background: var(--bg-surface-alt); }

  /* Kickoff time column */
  .fixture-time {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--text-secondary);
    min-width: 40px;
    text-align: center;
    flex-shrink: 0;
  }
  .fixture-time.today { color: var(--accent-blue); }

  /* Teams column */
  .fixture-teams {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .fixture-team-row {
    display: flex;
    align-items: center;
    gap: 7px;
  }
  .team-crest-sm {
    width: 20px; height: 20px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 7px; font-weight: 700; color: #fff;
    flex-shrink: 0;
  }
  .fixture-team-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-primary);
    flex: 1;
  }

  /* Right side actions */
  .fixture-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    flex-shrink: 0;
  }
  .notif-btn {
    width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 200ms;
  }
  .notif-btn:hover { background: var(--bg-surface-alt); color: var(--accent-blue); }
  .notif-btn.active { color: var(--accent-blue); }
  .notif-btn svg { width: 16px; height: 16px; }

  .venue-label {
    font-size: 10px;
    color: var(--text-muted);
    text-align: right;
    max-width: 80px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Status tags */
  .status-tag {
    font-size: 10px;
    font-weight: 600;
    padding: 2px 6px;
    border-radius: 3px;
    letter-spacing: 0.3px;
    flex-shrink: 0;
  }
  .status-tag.postponed { background: var(--bg-elevated); color: var(--accent-warning); }
  .status-tag.cancelled { background: var(--bg-elevated); color: var(--accent-danger); }
  .status-tag.tbc      { background: var(--bg-elevated); color: var(--text-muted); font-style: italic; }

  /* Odds snippet */
  .odds-row {
    display: flex;
    gap: 4px;
    margin-top: 3px;
  }
  .odds-pill {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    padding: 2px 6px;
    border-radius: 3px;
    background: var(--bg-elevated);
    color: var(--text-secondary);
    cursor: pointer;
    transition: background 150ms;
  }
  .odds-pill:hover { background: var(--bg-surface-alt); color: var(--text-primary); }
  .odds-label {
    font-size: 9px;
    color: var(--text-muted);
    align-self: center;
  }

  /* ── "Load More" / next week ─────────────────────────────── */
  .load-more-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 16px;
    color: var(--accent-blue);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    border-bottom: 1px solid var(--border-subtle);
  }

  /* ── Bottom Tab Bar ──────────────────────────────────────── */
  .bottom-tabs {
    position: fixed;
    bottom: 0; left: 50%;
    transform: translateX(-50%);
    width: 375px; height: 56px;
    background: var(--bg-surface);
    border-top: 1px solid var(--border);
    display: flex; align-items: stretch;
    z-index: 100;
  }
  .tab-item {
    flex: 1;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 3px; cursor: pointer;
    color: var(--text-muted); min-height: 44px;
    transition: color 200ms;
  }
  .tab-item.active { color: var(--accent-blue); }
  .tab-item svg { width: 22px; height: 22px; }
  .tab-label { font-size: 10px; font-weight: 500; }

  /* Crests */
  .c-arsenal   { background: #EF0107; }
  .c-mancity   { background: #97C1E7; color: #000 !important; }
  .c-liverpool { background: #C8102E; }
  .c-chelsea   { background: #034694; }
  .c-spurs     { background: #132257; }
  .c-manu      { background: #DA020E; }
  .c-newcastle { background: #241F20; border: 1px solid #555; }
  .c-aston     { background: #95BFE5; color: #4B0E10 !important; }
  .c-wolves    { background: #FDB913; color: #000 !important; }
  .c-brighton  { background: #0057B8; }
  .c-brentford { background: #E30613; }
  .c-westham   { background: #7A263A; }
  .c-everton   { background: #003399; }
  .c-realmadrid { background: #FABE00; color: #000 !important; }
  .c-barca     { background: #A50044; }
  .c-atletico  { background: #CB3524; }
  .c-psg       { background: #004170; }
  .c-dortmund  { background: #FDE100; color: #000 !important; }
  .c-bayern    { background: #DC052D; }
  .c-forest    { background: #DD0000; }

  .annotation-block {
    background: #080c18;
    border-top: 2px solid #1e2d5a;
    padding: 20px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: #5a6a9a;
    line-height: 1.8;
  }
</style>
</head>
